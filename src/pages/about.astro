---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getImage } from "astro:assets";
import Content2 from "@/components/widgets/Content2.astro";
import Values from "@/components/widgets/Values.astro";
import aboutImage from "@/assets/images/clean-saar-team.jpg"; 

const metadata = {
  title: "Über uns | Clean-Saar – Ihr Reinigungsteam im Saarland",
  description:
    "Erfahren Sie mehr über Clean-Saar. Wir sind Ihr lokaler Partner für Sauberkeit und Hygiene in Saarbrücken, Saarlouis und Völklingen.",
};

const values = [
  {
    title: "Gründlichkeit",
    description:
      "Sauberkeit ist kein Zufall. Wir arbeiten mit Checklisten und höchsten Standards, um jedes Mal ein perfektes Ergebnis zu liefern.",
  },
  {
    title: "Zuverlässigkeit",
    description:
      "Termintreue ist im Saarland Ehrensache. Wir erscheinen pünktlich und halten uns strikt an vereinbarte Reinigungsintervalle.",
  },
  {
    title: "Diskretion",
    description:
      "Ob Anwaltskanzlei oder Privathaus – wir wahren die Privatsphäre unserer Kunden und arbeiten absolut vertrauenswürdig.",
  },
  {
    title: "Umweltbewusstsein",
    description:
      "Wir setzen auf biologisch abbaubare Reinigungsmittel, um die Umwelt im schönen Saarland zu schützen.",
  },
  {
    title: "Transparenz",
    description:
      "Keine versteckten Kosten. Unsere Angebote sind fair, nachvollziehbar und auf Ihre Bedürfnisse zugeschnitten.",
  },
  {
    title: "Regionalität",
    description:
      "Wir sind stolz darauf, ein saarländisches Unternehmen zu sein und lokale Arbeitsplätze in der Region zu fördern.",
  },
];

const optimizedImage = await getImage({
  src: aboutImage,
  format: "webp",
});
---

<BaseLayout {metadata}>
  <link slot="head" rel="preload" href={optimizedImage.src} as="image" />
  
  <Content2
    title="Unsere Vision für ein sauberes Saarland"
    description={[
      "Clean-Saar wurde mit einem klaren Ziel gegründet: Professionelle Reinigungsdienstleistungen mit dem persönlichen Touch eines lokalen Familienunternehmens zu verbinden. Wir wissen, dass Sauberkeit die Basis für Wohlbefinden und Produktivität ist.",
      "Seit unserer Gründung unterstützen wir Unternehmen und Privathaushalte in Saarbrücken und Umgebung dabei, ihre Räumlichkeiten in bestem Licht erstrahlen zu lassen. Dabei setzen wir auf geschultes Personal, moderne Technik und ein tiefes Verständnis für die Bedürfnisse unserer saarländischen Kunden.",
    ]}
    tagline="Wer wir sind"
    image={aboutImage}
    imageAlt="Das Clean-Saar Team bei einer Objektbesichtigung in Saarbrücken"
    actions={[
      {
        text: "Jetzt kennenlernen",
        href: "/contact",
        variant: "primary",
        icon: "lucide:mail",
      },
      {
        text: "Unsere Leistungen",
        href: "/services",
        variant: "secondary",
        icon: "lucide:arrow-right",
      },
    ]}
  />

  <Values
    items={values}
    columns={3}
    tagline="Unsere Werte"
    title="Was uns auszeichnet"
    subtitle="Prinzipien, die unsere tägliche Arbeit in Ihren Räumen leiten."
  />
</BaseLayout>