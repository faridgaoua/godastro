---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Features from "@/components/widgets/Features.astro";
import Content from "@/components/widgets/Content.astro";
import Form from "@/components/ui/Form.astro";

const metadata = {
  title: "Kontakt & Angebot | Clean-Saar Saarbrücken",
  description: "Fordern Sie Ihr kostenloses Reinigungsangebot an. Wir beraten Sie gerne persönlich zu unseren Leistungen in Saarbrücken und Umgebung.",
};

const introText = [
  "Haben Sie Fragen zu unseren Reinigungsleistungen oder möchten Sie ein unverbindliches Angebot erhalten? Wir freuen uns auf Ihre Nachricht!",
  "Unser Team berät Sie kompetent und erstellt ein auf Ihre Bedürfnisse zugeschnittenes Reinigungskonzept."
];
---

<BaseLayout {metadata}>
  <Content tagline="Kontakt" title="Wir freuen uns auf Sie" description={introText} />
  
  <!-- <div
    class="reveal mx-auto max-w-xl bg-card border border-border rounded-3xl p-8 shadow-sm mb-12 md:mb-16"
  >
    <h2 class="text-xl font-bold mb-6 text-center">Angebot anfordern</h2>
    <Form />
  </div> -->

  <Features
    tagline="Erreichbarkeit"
    title="So finden Sie uns"
    subtitle="Wir sind während unserer Geschäftszeiten für Sie da und antworten in der Regel innerhalb von 24 Stunden."
    classes={{ container: "pt-0 md:pt-0" }}
    features={[
      {
        title: "Telefon",
        description: "0681 / 123 4567",
        icon: "lucide:phone",
        iconClass: "bg-[#00BCA5]/10 text-[#00BCA5]",
      },
      {
        title: "E-Mail",
        description: "info@clean-saar.de",
        icon: "lucide:mail",
        iconClass: "bg-[#00BCA5]/10 text-[#00BCA5]",
      },
      {
        title: "Standort",
        description: "Mainzer Str. 12, 66111 Saarbrücken",
        icon: "lucide:map-pin",
        iconClass: "bg-red-500/10 text-red-400",
      },
      {
        title: "Kostenlose Besichtigung",
        description: "Wir besichtigen Ihr Objekt vor Ort in Saarbrücken für ein faires Festpreis-Angebot.",
        icon: "lucide:eye",
        iconClass: "bg-yellow-500/10 text-yellow-400",
      },
      {
        title: "Schnelle Reaktionszeit",
        description: "Anfragen per Formular oder E-Mail werden meist noch am selben Tag bearbeitet.",
        icon: "lucide:zap",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
      {
        title: "Regionale Nähe",
        description: "Egal ob Dudweiler, St. Johann oder Völklingen – wir sind Ihr Partner in der Nachbarschaft.",
        icon: "lucide:home",
        iconClass: "bg-orange-500/10 text-orange-400",
      },
    ]}
  />
</BaseLayout>