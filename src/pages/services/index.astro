---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ServiceList from "@/components/widgets/ServiceList.astro";
import Content from "@/components/widgets/Content.astro";
import Content2 from "@/components/widgets/Content2.astro";
import bueroImg from "@/assets/images/services/bueroreinigung.jpg";
import fensterImg from "@/assets/images/services/fensterreinigung.jpg";
import sonderImg from "@/assets/images/services/sonderreinigung.jpg";

const services = [
  {
    title: "Büroreinigung",
    description: "Professionelle Unterhaltsreinigung für produktive Arbeitswelten.",
    icon: "lucide:briefcase",
    callToAction: {
      text: "Details ansehen",
      href: "/services/bueroreinigung",
    },
  },
  {
    title: "Glasreinigung",
    description: "Streifenfreier Durchblick für Schaufenster und Fassaden.",
    icon: "lucide:sun",
    callToAction: {
      text: "Details ansehen",
      href: "/services/glasreinigung",
    },
  },
  {
    title: "Baureinigung",
    description: "Wir beseitigen den Baustaub, damit Sie einziehen können.",
    icon: "lucide:hard-hat",
    callToAction: {
      text: "Details ansehen",
      href: "/services/baureinigung",
    },
  },
];

const metadata = {
  title: "Unsere Leistungen | Professionelle Reinigung in Saarbrücken",
  description:
    "Von der täglichen Büroreinigung bis zur speziellen Glas- und Baureinigung – Clean-Saar bietet maßgeschneiderte Konzepte für das gesamte Saarland.",
};
---

<BaseLayout {metadata}>
  <Content
    tagline="Leistungen"
    title="Sauberkeit nach Maß"
    description={[
      "Wir bieten Ihnen ein breites Spektrum an Reinigungsdienstleistungen, die exakt auf Ihre Räumlichkeiten in Saarbrücken abgestimmt sind.",
    ]}
  />
  
  <ServiceList services={services} classes={{ container: "pt-0 md:pt-0" }} />

  <Content2
    items={[
      {
        title: "Individuelle Intervalle",
        description:
          "Täglich, wöchentlich oder monatlich – wir passen uns Ihrem Geschäftsbetrieb an.",
      },
      {
        title: "Hygienekonzept",
        description:
          "Desinfektion von Kontaktflächen (Türklinken, Tastaturen) nach aktuellen Standards.",
      },
    ]}
    image={bueroImg}
    imageAlt="Professionelle Büroreinigung in einem Saarbrücker Büro"
    classes={{ container: "pt-0 md:pt-0" }}
  >
    <Fragment>
      <a href="/services/bueroreinigung" class="group cursor-pointer">
        <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 group-hover:text-primary transition-colors">
          Büro- & Unterhaltsreinigung →
        </h3>
      </a>
      Ein sauberes Büro ist die Visitenkarte Ihres Unternehmens. Wir sorgen diskret und gründlich für eine Atmosphäre, in der sich Mitarbeiter und Kunden wohlfühlen.
    </Fragment>
  </Content2>

  <Content2
    isReversed={true}
    items={[
      {
        title: "Rahmenpflege inklusive",
        description:
          "Wir reinigen nicht nur das Glas, sondern pflegen auch Rahmen und Falze für langlebige Fenster.",
      },
      {
        title: "Schaufenster-Service",
        description:
          "Regelmäßiger Glanz für Ihren Einzelhandel in der Saarbrücker Innenstadt.",
      },
    ]}
    image={fensterImg}
    imageAlt="Fensterputzer bei der Arbeit am Schaufenster"
  >
    <Fragment>
      <a href="/services/glasreinigung" class="group cursor-pointer">
        <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 group-hover:text-primary transition-colors">
          Glas- & Fensterreinigung →
        </h3>
      </a>
      Streifenfreier Glanz steigert den Wert Ihrer Immobilie. Wir reinigen Glasflächen jeder Art, auch an schwer zugänglichen Stellen mit modernem Equipment.
    </Fragment>
  </Content2>

  <Content2
    items={[
      {
        title: "Teppichreinigung",
        description:
          "Tiefenreinigung von textilen Bodenbelägen für ein frisches Raumklima.",
      },
      {
        title: "Grundreinigung",
        description:
          "Einmalige Intensivreinigung zur Entfernung hartnäckiger Verschmutzungen.",
      },
    ]}
    image={sonderImg}
    imageAlt="Industrielle Bodenreinigung"
  >
    <Fragment>
      <a href="/services/baureinigung" class="group cursor-pointer">
        <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2 group-hover:text-primary transition-colors">
          Sonder- & Grundreinigung →
        </h3>
      </a>
      Manchmal reicht die normale Pflege nicht aus. Unsere Spezialteams kümmern sich um Härtefälle, von der Baustellensäuberung bis zur Versiegelung von Hartböden.
    </Fragment>
  </Content2>
</BaseLayout>