---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/widgets/Hero.astro";

const metadata = {
  title: "404 - Seite nicht gefunden | Clean-Saar",
  description: "Hoppla! Diese Seite wurde bereits weggeputzt. Kehren Sie zurück zur Startseite von Clean-Saar Saarbrücken.",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <Hero
    title={`<h1 class="bg-linear-to-r from-[#00BCA5] via-[#00BCA5] to-cyan-500 bg-clip-text text-transparent text-[10rem] md:text-[12rem] font-extrabold tracking-tighter mb-4">404</h1>`}
    tagline="Hoppla! Da war unser Putzteam wohl zu gründlich."
    description="Die gesuchte Seite wurde anscheinend weggewischt oder existiert nicht mehr. Kein Grund zur Sorge – wir helfen Ihnen gerne zurück auf den richtigen Weg."
    actions={[
      {
        variant: "primary",
        text: "Zur Startseite",
        href: "/",
        icon: "lucide:home",
      },
      {
        variant: "secondary",
        text: "Kontakt aufnehmen",
        href: "/contact",
        icon: "lucide:phone",
      },
    ]}
  />
</BaseLayout>