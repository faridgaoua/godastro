---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import Headline from "@/components/ui/Headline.astro";
import PostItem from "@/components/blog/PostItem.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  const posts = allPosts.filter((post) => post.data && post.data.pubDate); 

  const tags = new Set();
  posts.forEach((post) => {
    post.data.tags?.forEach((tag) => tags.add(tag));
  });

  return Array.from(tags).map((tag) => {
    return {
      params: { tag: tag as string },
      props: {
        tag,
        posts: posts.filter((post) => post.data.tags?.includes(tag as string)),
      },
    };
  });
}

const { tag, posts } = Astro.props;

// Localized Metadata
const metadata = {
  title: `Beiträge zum Thema "${tag}" | Clean-Saar`,
  description: `Alle unsere Artikel und Ratgeber zum Thema ${tag} für Kunden im Saarland.`,
};
---

<BaseLayout metadata={metadata}>
  <section class="relative px-4 py-16 sm:px-6 lg:px-8 md:py-24">
    <div class="absolute inset-0 -z-10 bg-linear-to-b from-[#00BCA5]/5 to-transparent"></div>
    
    <div class="relative mx-auto max-w-5xl">
      <div class="mb-8 text-center">
        <a href="/blog" class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-[#00BCA5] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Zurück zum Ratgeber
        </a>
      </div>

      <Headline
        tagline="Kategorie"
        title={`Thema: ${tag}`}
        subtitle={`Wir haben ${posts.length} ${posts.length === 1 ? "Beitrag" : "Beiträge"} gefunden.`}
        classes={{
          container: "mb-12 text-center",
          title: "font-heading mb-4 text-4xl font-bold tracking-tight text-foreground md:text-6xl capitalize",
          subtitle: "mx-auto max-w-3xl text-xl text-muted-foreground",
        }}
      />

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          posts
            .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
            .map((post) => <PostItem post={post} />)
        }
      </div>
    </div>
  </section>
</BaseLayout>