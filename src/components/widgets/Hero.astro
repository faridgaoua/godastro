---
import WidgetWrapper from "./WidgetWrapper.astro";
import type { HeroProps } from "@/types/types";
import Headline from "@/components/ui/Headline.astro";
import Button from "@/components/ui/Button.astro";
import { Icon } from "astro-icon/components";

// Wir erweitern die Props um bgImage
interface Props extends HeroProps {
  bgImage?: string;
}

const {
  title = await Astro.slots.render("title"),
  tagline,
  description = await Astro.slots.render("description"),
  actions = [],
  id,
  isDark = true,
  classes = {},
  bg = await Astro.slots.render("bg"),
  animate = false,
  // Standardbild, falls keins übergeben wird
  bgImage = "",
} = Astro.props;

const { container: containerClassProp = "" } = classes;
---

<WidgetWrapper
  id={id}
  isDark={isDark}
  containerClass={`min-h-[calc(100vh-72px)] flex flex-col justify-center relative overflow-hidden ${containerClassProp}`}
  bg={bg}
  animate={animate}
>
  <div class="absolute inset-0 z-0">
    {
      bgImage && (
        <img
          src={bgImage}
          alt="Hintergrund Reinigungsservice"
          class="w-full h-full object-cover"
        />
      )
    }
    <div class="absolute inset-0 bg-black/50 backdrop-blur-[1px]"></div>
  </div>

  <div class="text-center relative z-10 px-4">
    {
      tagline && (
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 border border-white/20 text-white text-xs font-semibold mb-6 backdrop-blur-md">
          <span class="relative flex h-2 w-2" aria-hidden="true">
            <span class="absolute inline-flex h-full w-full rounded-full bg-[#00BCA5]/60 opacity-75 animate-ping" />
            <span class="relative inline-flex h-2 w-2 rounded-full bg-[#00BCA5]" />
          </span>
          {tagline}
        </div>
      )
    }
    {
      (title || description) && (
        <Headline
          title={title}
          subtitle={description}
          titleAs="h1"
          classes={{
            container: "mb-0 max-w-none",
            title:
              "text-5xl md:text-7xl font-extrabold tracking-tight text-white mb-6 drop-shadow-md",
            subtitle:
              "max-w-2xl mx-auto text-xl text-slate-200 mb-10 drop-shadow-sm",
          }}
        />
      )
    }

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      {
        Array.isArray(actions) &&
          actions.length > 0 &&
          actions.map((action) => (
            <Button
              href={action.href}
              variant={action.variant as "primary" | "secondary"}
              size="lg"
              aria-label={action.ariaLabel}
              class="w-full sm:w-auto shadow-xl"
            >
              {action.icon && (
                <Icon name={action.icon} class="w-5 h-5 mr-2 -ml-1" />
              )}
              {action.text}
            </Button>
          ))
      }
    </div>
  </div>
  <slot />
</WidgetWrapper>
