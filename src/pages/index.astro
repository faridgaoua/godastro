---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import Hero from "@/components/widgets/Hero.astro";
import Features from "@/components/widgets/Features.astro";
import devImg from "@/assets/images/cleaning-team.jpg"; // Rename or replace assets
import openSourceImg from "@/assets/images/saarland-service.jpg";
import Content2 from "@/components/widgets/Content2.astro";
import aboutImage from "@/assets/images/clean-saar-team.jpg"; 

const metadata = {
  // SEO Primary: Use the main keyword + Brand + Location
  title: `Professionelle Reinigung in Saarbrücken | Clean-Saar`,
  description:
    "Clean-Saar ist Ihr zuverlässiger Partner für Gebäudereinigung, Büroreinigung und Fensterreinigung in Saarbrücken und dem gesamten Saarland. Jetzt Angebot anfordern!",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <Content2
    title={`Glänzende Sauberkeit für <br class="hidden md:block" /> <span class="bg-linear-to-r from-[#00BCA5] via-[#00BCA5] to-[#00BCA5] bg-clip-text text-transparent">Saarbrücken & Umgebung</span>`}
    tagline="Clean-Saar: Zuverlässig. Gründlich. Regional."
    description="Vom Privathaushalt bis zum Großraumbüro – wir sorgen für hygienische Reinheit im gesamten Saarland. Erfahren Sie, warum Unternehmen in Saarbrücken auf unseren Service vertrauen."
    actions={[
      {
        text: "Kostenloses Angebot",
        href: "/kontakt",
        variant: "primary",
        icon: "lucide:calendar-check",
      },
      {
        text: "Unsere Leistungen",
        href: "/services",
        variant: "secondary",
        icon: "lucide:arrow-right",
        ariaLabel: "Erfahren Sie mehr über unsere Reinigungsleistungen",
      },
    ]}
  />
  <!-- <Hero
    title={`Glänzende Sauberkeit für <br class="hidden md:block" /> <span class="bg-linear-to-r from-[#00BCA5] via-[#00BCA5] to-[#00BCA5] bg-clip-text text-transparent">Saarbrücken & Umgebung</span>`}
    tagline="Clean-Saar: Zuverlässig. Gründlich. Regional."
    description="Vom Privathaushalt bis zum Großraumbüro – wir sorgen für hygienische Reinheit im gesamten Saarland. Erfahren Sie, warum Unternehmen in Saarbrücken auf unseren Service vertrauen."
    actions={[
      {
        text: "Kostenloses Angebot",
        href: "/kontakt",
        variant: "primary",
        icon: "lucide:calendar-check",
      },
      {
        text: "Unsere Leistungen",
        href: "/services",
        variant: "secondary",
        icon: "lucide:arrow-right",
        ariaLabel: "Erfahren Sie mehr über unsere Reinigungsleistungen",
      },
    ]}
  /> -->

  <Features
    tagline="Ihre Vorteile"
    title="Warum Clean-Saar?"
    subtitle="Qualität und Diskretion für Ihre Räumlichkeiten in der Landeshauptstadt."
    features={[
      {
        title: "Regionale Expertise",
        description:
          "Als saarländisches Unternehmen sind wir schnell vor Ort – egal ob St. Johann, Dudweiler oder Saarlouis.",
        icon: "lucide:map-pin",
        iconClass: "bg-[#00BCA5]/10 text-[#00BCA5]",
      },
      {
        title: "Flexible Termine",
        description:
          "Büroreinigung nach Feierabend oder Express-Reinigung bei Umzug? Wir richten uns nach Ihnen.",
        icon: "lucide:clock",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
      {
        title: "Umweltfreundlich",
        description:
          "Wir nutzen nachhaltige Reinigungsmittel, die schonend für Ihre Oberflächen und die Umwelt sind.",
        icon: "lucide:leaf",
        iconClass: "bg-[#00BCA5]/10 text-[#00BCA5]",
      },
    ]}
  />

  <Content2
    items={[
      {
        title: "Büroreinigung",
        description:
          "Saubere Arbeitsplätze für motivierte Mitarbeiter in ganz Saarbrücken.",
        icon: "lucide:briefcase",
        iconClass: "bg-[#00BCA5]/10 text-[#00BCA5]",
      },
      {
        title: "Fensterreinigung",
        description:
          "Streifenfreier Glanz für Schaufenster und private Glasflächen.",
        icon: "lucide:sun",
        iconClass: "bg-yellow-500/10 text-yellow-400",
      },
      {
        title: "Unterhaltsreinigung",
        description:
          "Regelmäßige Pflege für langfristigen Werterhalt Ihrer Immobilien.",
        icon: "lucide:shield-check",
        iconClass: "bg-pink-500/10 text-pink-400",
      },
    ]}
    image={devImg}
    imageAlt="Clean-Saar Team bei der Arbeit in Saarbrücken"
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Gewerbliche Reinigung
      </h3>
      Wir bieten maßgeschneiderte Reinigungskonzepte für Büros, Praxen und Kanzleien
      im Saarland.
    </Fragment>
  </Content2>

  <Content2
    items={[
      {
        title: "Endreinigung",
        description:
          "Perfekte Sauberkeit für die Wohnungsübergabe bei Auszug oder Einzug.",
        icon: "lucide:home",
        iconClass: "bg-indigo-500/10 text-indigo-400",
      },
      {
        title: "Treppenhausreinigung",
        description:
          "Ein gepflegtes Entree für Mehrfamilienhäuser und Wohnanlagen.",
        icon: "lucide:layers",
        iconClass: "bg-orange-500/10 text-orange-400",
      },
      {
        title: "Sonderreinigung",
        description:
          "Hartnäckige Verschmutzungen? Wir haben das richtige Equipment.",
        icon: "lucide:sparkles",
        iconClass: "bg-teal-500/10 text-teal-400",
      },
    ]}
    image={openSourceImg}
    imageAlt="Privater Reinigungsservice Saarland"
    isReversed={true}
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Privat & Wohnen
      </h3>
      Gönnen Sie sich mehr Freizeit. Wir übernehmen den Hausputz professionell, diskret
      und gründlich.
    </Fragment>
  </Content2>
</BaseLayout>
